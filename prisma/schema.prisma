// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Store {
  id Int @id @default(autoincrement())
  name String
  businessName String
  identification  String
  email String @unique
  phones Json
  logo String
  frontPageImg String
  geolocalizacion Json
  ownerId Int @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Permissions {
  id Int @id @default(autoincrement())
  code String @unique
  name String @unique
  description String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Roles {
  id Int @id @default(autoincrement())
  code String @unique
  name String @unique
  description String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PermissionRoles {
  id Int @id @default(autoincrement())
  permissionId Int
  roleId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([permissionId, roleId])
}


model Users {
  id Int @id @default(autoincrement())
  firstName String
  lastName String
  identification String @unique
  email String @unique
  bornDate DateTime
  phone Json
  age Int
  address String
  aditionalPermissions Json
  storeId Int?
  password String
  @@index([storeId])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}